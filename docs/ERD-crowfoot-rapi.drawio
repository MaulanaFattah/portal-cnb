<mxCell id="rel_note432" value="Ringkasan Relasi (FK)&#xa;1. akun_pengguna.id -&gt; profil_guru.akun_pengguna_id (1:1; onDelete CASCADE)&#xa;2. akun_pengguna.id -&gt; profil_guru.disetujui_oleh_akun_pengguna_id (1:N approve; onDelete SET NULL)&#xa;3. kelas.id -&gt; profil_guru.kelas_id (1:N; onDelete SET NULL)&#xa;4. akun_pengguna.id -&gt; jadwal_mengajar.guru_akun_pengguna_id (1:N; onDelete CASCADE)&#xa;5. kelas.id -&gt; jadwal_mengajar.kelas_id (1:N; onDelete CASCADE)&#xa;6. kelas.id -&gt; siswa.kelas_id (1:N; onDelete SET NULL)&#xa;7. akun_pengguna.id -&gt; tautan_akun_portal.akun_pengguna_id (1:N; onDelete CASCADE)&#xa;8. siswa.id -&gt; tautan_akun_portal.siswa_id (1:N; onDelete CASCADE)&#xa;9. akun_pengguna.id -&gt; log_audit.pelaku_akun_pengguna_id (1:N; onDelete SET NULL)&#xa;10. siswa.id -&gt; absensi_siswa.siswa_id (1:N; onDelete CASCADE)&#xa;11. jadwal_mengajar.id -&gt; absensi_siswa.jadwal_mengajar_id (1:N; onDelete SET NULL)&#xa;12. akun_pengguna.id -&gt; absensi_siswa.guru_akun_pengguna_id (1:N; onDelete CASCADE)&#xa;13. kelas.id -&gt; absensi_siswa.kelas_id (1:N; onDelete CASCADE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fed7aa;fontSize=11;fontColor=#7c2d12;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="2580" y="1000" width="1060" height="340" as="geometry"/></mxCell></root>
